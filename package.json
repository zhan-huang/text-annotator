{
  "name": "text-annotator",
  "version": "0.8.2",
  "description": "A JavaScript library for locating and annotating plain text in HTML",
  "main": "build/text-annotator.js",
  "scripts": {
    "build": "babel src -d build",
    "build-min": "webpack --config webpack.config.js",
    "lint": "eslint 'src/text-annotator.ts' --quiet --fix",
    "build-ts": "tsc --project tsconfig.json",
    "sync": "node sync.js",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhan-huang/text-annotator.git"
  },
  "author": "Zhan Huang",
  "license": "MIT",
  "keywords": [
    "text annotating",
    "html",
    "web"
  ],
  "bugs": {
    "url": "https://github.com/zhan-huang/text-annotator/issues"
  },
  "homepage": "https://github.com/zhan-huang/text-annotator",
  "devDependencies": {
    "@babel/cli": "^7.8.4",
    "@babel/core": "^7.8.7",
    "@babel/preset-env": "^7.8.7",
    "@typescript-eslint/eslint-plugin": "^4.6.1",
    "@typescript-eslint/parser": "^4.6.1",
    "babel-jest": "^25.1.0",
    "dotenv": "^8.0.0",
    "eslint": "^7.12.1",
    "eslint-config-prettier": "^6.15.0",
    "eslint-plugin-prettier": "^3.1.4",
    "jest": "^24.5.0",
    "pre-commit": "^1.2.2",
    "prettier": "^2.1.2",
    "sync-directory": "^2.0.8",
    "typescript": "^4.0.5",
    "webpack": "^4.29.6",
    "webpack-cli": "^3.3.0"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ]
    ]
  },
  "pre-commit": [
    "test"
  ],
  "dependencies": {
    "html-entities": "^1.3.1"
  }
}
